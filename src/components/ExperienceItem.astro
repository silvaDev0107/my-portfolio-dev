---

interface ExperienceItemProps{
    dateStart: string,
    dateEnd: string,
    role: string,
    description: string,
    empresa: string
}

const {dateStart , dateEnd, role, description, empresa} = Astro.props as ExperienceItemProps;
---

<li class="mb-10 ms-4">
  <div
    class="absolute w-3 h-3 bg-accent rounded-full mt-1.5 -start-1.5 border"
  >
  </div>

  <h3 class="text-lg font-semibold my-2">{role}</h3>
  <h5 class="text-md font-semibold">{empresa}</h5>

  <span class="text-sm text-text-secondary font-semibold leading-none">
    <time >{dateStart}</time> - <time>{dateEnd}</time>
  </span>
  
  <p class="mb-4 text-base font-normal">
    {description}
  </p>
</li>
